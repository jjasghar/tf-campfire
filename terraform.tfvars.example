# =============================================================================
# Terraform Campfire Deployment Configuration
# =============================================================================
# This file contains example configurations for deploying Campfire on either
# IBM Cloud or DigitalOcean. Choose the appropriate section and uncomment
# the variables you need.
#
# For detailed setup instructions, see README.md
# =============================================================================

# =============================================================================
# CLOUD PROVIDER SELECTION
# =============================================================================
# Choose your cloud provider: "ibm" or "digitalocean"
# This single variable determines which resources are created
cloud_provider = "ibm"  # Change to "digitalocean" for DigitalOcean deployment

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================
# Basic project settings (used by both providers)
project_name = "campfire"        # Name prefix for all resources
domain_name  = "example.com"     # Your domain name (must be managed by DNSimple)
subdomain    = "chat"            # Subdomain for the Campfire instance

# =============================================================================
# DNSIMPLE CONFIGURATION
# =============================================================================
# Required for both providers - DNSimple manages DNS records
dnsimple_token   = "your-dnsimple-api-token"     # Get from: https://dnsimple.com/user
dnsimple_account = "your-dnsimple-account-id"    # Get from: https://dnsimple.com/account

# =============================================================================
# SSH CONFIGURATION
# =============================================================================
# SSH key for accessing the deployed instance
# Choose one of the following options:

# Option 1: Provide your public key (recommended for DigitalOcean, optional for IBM Cloud)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC... your-email@example.com"

# Option 2: Use existing IBM Cloud SSH key (IBM Cloud only)
# ibm_ssh_key_id = "your-ibm-cloud-ssh-key-id"

# Option 3: Use existing DigitalOcean SSH key (DigitalOcean only)
# digitalocean_ssh_key_id = "your-digitalocean-ssh-key-id"

# Path to your private key for remote-exec provisioners
ssh_private_key_path = "~/.ssh/id_rsa"

# =============================================================================
# PRODUCTION vs TEST MODE
# =============================================================================
# Production mode: clean domain (e.g., chat.example.com)
# Test mode: adds random hash (e.g., chat-abc123.example.com)
production   = true   # Set to false for testing with random domain hash
hash_length  = 6      # Length of random hash (4-12 characters, only used when production = false)

# =============================================================================
# CAMPFIRE APPLICATION CONFIGURATION
# =============================================================================
# Optional: Leave empty to generate automatically
vapid_public_key  = ""  # Web Push VAPID public key
vapid_private_key = ""  # Web Push VAPID private key
sentry_dsn        = ""  # Sentry DSN for error reporting (leave empty to disable)

# =============================================================================
# TAGS
# =============================================================================
# Tags applied to all resources
tags = ["terraform", "campfire", "production"]

# =============================================================================
# IBM CLOUD CONFIGURATION
# =============================================================================
# Only used when cloud_provider = "ibm"
# Uncomment and configure these variables for IBM Cloud deployment

# IBM Cloud API Key (required for IBM Cloud)
# Get from: https://cloud.ibm.com/iam/apikeys
# ibm_api_key = "your-ibm-cloud-api-key"

# IBM Cloud region and zone
# ibm_region = "us-south"  # Available: us-south, us-east, eu-gb, eu-de, jp-tok, au-syd
# zone = "1"               # Zone within the region (1, 2, or 3)

# IBM Cloud resource group ID
# Get from: ibmcloud resource groups
# resource_group_id = "your-resource-group-id"

# IBM Cloud instance configuration
# instance_image   = "r134-4a0a0a0a-4a0a-4a0a-4a0a-4a0a0a0a0a0a"  # Ubuntu 22.04 LTS
# instance_profile = "cx2-2x4"  # Available: cx2-2x4, cx2-4x8, cx2-8x16, cx2-16x32

# Network configuration for IBM Cloud VPC
# subnet_cidr = "10.240.0.0/24"

# =============================================================================
# DIGITALOCEAN CONFIGURATION
# =============================================================================
# Only used when cloud_provider = "digitalocean"
# Uncomment and configure these variables for DigitalOcean deployment

# DigitalOcean API Token (required for DigitalOcean)
# Get from: https://cloud.digitalocean.com/account/api/tokens
# digitalocean_token = "your-digitalocean-api-token"

# DigitalOcean region
# Available regions: nyc1, nyc3, sfo3, sgp1, lon1, fra1, tor1, blr1
# digitalocean_region = "nyc3"

# DigitalOcean droplet size
# Available sizes: s-1vcpu-1gb, s-2vcpu-2gb, s-2vcpu-4gb, s-4vcpu-8gb, s-8vcpu-16gb
# digitalocean_size = "s-2vcpu-4gb"

# DigitalOcean SSH key ID (alternative to ssh_public_key)
# Get from: doctl compute ssh-key list
# digitalocean_ssh_key_id = "your-digitalocean-ssh-key-id"

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Example 1: IBM Cloud Production Deployment
# cloud_provider = "ibm"
# ibm_api_key = "your-ibm-cloud-api-key"
# ibm_region = "us-south"
# zone = "1"
# resource_group_id = "your-resource-group-id"
# production = true

# Example 2: IBM Cloud Test Deployment
# cloud_provider = "ibm"
# ibm_api_key = "your-ibm-cloud-api-key"
# ibm_region = "us-south"
# zone = "1"
# resource_group_id = "your-resource-group-id"
# production = false
# hash_length = 6

# Example 3: DigitalOcean Production Deployment (with existing SSH key)
# cloud_provider = "digitalocean"
# digitalocean_token = "your-digitalocean-api-token"
# digitalocean_region = "nyc3"
# digitalocean_size = "s-2vcpu-4gb"
# digitalocean_ssh_key_id = "your-digitalocean-ssh-key-id"
# production = true

# Example 4: DigitalOcean Test Deployment (with new SSH key)
# cloud_provider = "digitalocean"
# digitalocean_token = "your-digitalocean-api-token"
# digitalocean_region = "nyc3"
# digitalocean_size = "s-2vcpu-4gb"
# ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC... your-email@example.com"
# production = false
# hash_length = 6